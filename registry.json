{
  "version": 1,
  "plugins": [
    {
      "id": "controller-battery",
      "name": "Controller Battery",
      "version": "1.0.0",
      "minNoctaliaVersion": "3.6.0",
      "author": "rael2pac",
      "license": "MIT",
      "repository": "https://github.com/rael2pac/NixOS",
      "description": "Shows battery level of connected wireless controllers (PS4, PS5, Xbox) in the bar",
      "tags": [
        "Bar",
        "Panel",
        "Hardware"
      ],
      "entryPoints": {
        "barWidget": "BarWidget.qml",
        "panel": "Panel.qml"
      },
      "dependencies": {
        "plugins": []
      },
      "metadata": {
        "defaultSettings": {
          "refreshInterval": 15000,
          "showLowestOnly": true
        }
      }
    },
    {
      "id": "hdmi-toggle",
      "name": "HDMI Toggle",
      "version": "2.0.0",
      "minNoctaliaVersion": "3.6.0",
      "author": "rael2pac",
      "license": "MIT",
      "repository": "https://github.com/rael2pac/NixOS",
      "description": "List all monitors and toggle each on/off via Niri compositor",
      "tags": [
        "Bar",
        "Panel",
        "Hardware"
      ],
      "entryPoints": {
        "barWidget": "BarWidget.qml",
        "panel": "Panel.qml"
      },
      "dependencies": {
        "plugins": []
      },
      "metadata": {
        "defaultSettings": {}
      }
    },
    {
      "id": "nix-manager",
      "name": "Nix Manager",
      "version": "1.0.0",
      "minNoctaliaVersion": "3.6.0",
      "author": "rael2pac",
      "license": "MIT",
      "repository": "https://github.com/rael2pac/NixOS",
      "description": "NixOS system update and cleanup buttons in the panel",
      "tags": [
        "Bar",
        "Panel"
      ],
      "entryPoints": {
        "barWidget": "BarWidget.qml",
        "panel": "Panel.qml"
      },
      "dependencies": {
        "plugins": []
      },
      "metadata": {
        "defaultSettings": {}
      }
    }
  ]
}